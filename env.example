# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USERS=123456789,987654321  # Comma-separated user IDs (leave empty for all users)

# Render Configuration (will be set automatically)
RENDER_EXTERNAL_URL=https://your-app.onrender.com
PORT=8000

# Database (will be set automatically by Render)
DATABASE_URL=sqlite:///instagram_bot.db

# Captcha Configuration (Optional)
CAPTCHA_2CAPTCHA_KEY=your_2captcha_api_key  # Optional - for fallback

# Proxy Configuration (Optional)
USE_PROXY=false
PROXY_LIST=  # Comma-separated proxy list if needed

# Logging
LOG_LEVEL=INFO
